{
  "name": "@managecallai/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing ManageCallAI IVR lifecycle tools to AI agents",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary"
  },
  "bin": {
    "managecall-mcp": "./dist/index.js"
  },
  "dependencies": {
    "@managecallai/contracts": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
