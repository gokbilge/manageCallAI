<configuration name="xml_curl.conf" description="XML Curl">
  <bindings>
    <binding name="directory">
      <param name="gateway-url" value="http://host.docker.internal:3000/api/v1/freeswitch/directory?runtime_token=change-me-runtime-token" />
      <param name="method" value="post" />
    </binding>
  </bindings>
</configuration>
