<include>
  <!--
    Smoke test echo extension. Activated only when FREESWITCH_TLS_ENABLED=true
    (via entrypoint.sh). Provides a deterministic echo target for the TLS/SRTP/NAT
    smoke test script (scripts/sip-tls-srtp-smoke.mjs).

    Extension 747: answers immediately, runs the echo application, and hangs up
    after 10 seconds. Reachable in the public context (external profile).
  -->
  <extension name="smoke-echo">
    <condition field="destination_number" expression="^747$">
      <action application="answer"/>
      <action application="echo"/>
      <action application="sleep" data="10000"/>
      <action application="hangup"/>
    </condition>
  </extension>
</include>
