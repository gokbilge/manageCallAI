{
  "name": "managecallai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@managecallai/contracts": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "yaml": "^2.8.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:check": "node ./db/migrate.mjs",
    "check:migrations": "node ./scripts/check-migration-order.mjs",
    "db:constraints": "node ./scripts/check-db-constraints.mjs",
    "db:contracts": "node ./scripts/check-db-contracts.mjs",
    "db:migrate": "node ./db/migrate.mjs",
    "db:status": "node ./db/migrate.mjs --status",
    "db:up": "docker compose up -d postgres",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @managecallai/api dev",
    "dev:web": "pnpm --filter @managecallai/web dev",
    "lint": "pnpm -r lint",
    "runtime:up": "docker compose --profile freeswitch up -d",
    "runtime:down": "docker compose --profile freeswitch down",
    "runtime:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/live-runtime-smoke.ps1",
    "test": "pnpm -r test",
    "test:coverage": "pnpm coverage:api && pnpm coverage:web && pnpm coverage:mcp && pnpm coverage:sdk && pnpm coverage:freeswitch-agent",
    "coverage:api": "pnpm --filter @managecallai/api test:coverage",
    "coverage:web": "pnpm --filter @managecallai/web test:coverage",
    "coverage:mcp": "pnpm --filter @managecallai/mcp test:coverage",
    "coverage:sdk": "pnpm --filter @managecallai/sdk test:coverage",
    "coverage:freeswitch-agent": "cd apps/freeswitch-agent && go test ./... -cover",
    "generate:openapi": "node scripts/generate-openapi.mjs",
    "generate:web-types": "node scripts/generate-web-types.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:mcp-schemas": "node scripts/check-mcp-schemas.mjs",
    "check:mcp-contracts": "node scripts/check-mcp-contracts.mjs",
    "check:webhook-payloads": "node scripts/check-webhook-payloads.mjs",
    "check:api-key-capabilities": "node scripts/check-api-key-capabilities.mjs",
    "check:ivr-simulation": "node scripts/check-ivr-simulation.mjs",
    "check:freeswitch-profile": "node scripts/check-freeswitch-profile.mjs",
    "check:coverage-ignores": "node scripts/check-coverage-ignores.mjs"
  }
}
