{
  "name": "managecallai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@managecallai/contracts": "workspace:*",
    "yaml": "^2.8.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:check": "node ./db/migrate.mjs",
    "db:migrate": "node ./db/migrate.mjs",
    "db:status": "node ./db/migrate.mjs --status",
    "db:up": "docker compose up -d postgres",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @managecallai/api dev",
    "dev:web": "pnpm --filter @managecallai/web dev",
    "lint": "pnpm -r lint",
    "runtime:up": "docker compose --profile freeswitch up -d",
    "runtime:down": "docker compose --profile freeswitch down",
    "runtime:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/live-runtime-smoke.ps1",
    "test": "pnpm -r test",
    "generate:openapi": "node scripts/generate-openapi.mjs",
    "generate:web-types": "node scripts/generate-web-types.mjs"
  }
}
