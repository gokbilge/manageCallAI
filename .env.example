POSTGRES_DB=managecallai
POSTGRES_USER=managecallai
POSTGRES_PASSWORD=managecallai
POSTGRES_PORT=5432
DATABASE_URL=postgres://managecallai:managecallai@localhost:5432/managecallai
API_PORT=3000
APP_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-in-production
# Preferred runtime auth: Authorization: Bearer <RUNTIME_API_TOKEN>
# Query/body runtime_token is kept only for local development or constrained mod_xml_curl setups.
ALLOW_RUNTIME_TOKEN_FALLBACK=true
RUNTIME_API_TOKEN=change-me-runtime-token
# Optional rolling rotation token. Leave empty unless actively rotating runtime credentials.
RUNTIME_API_TOKEN_SECONDARY=
# AES-256-GCM key for SIP password encryption-at-rest.
# Must be 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
SIP_SECRET_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Identifies the active key; stored alongside every ciphertext for future key rotation.
SIP_SECRET_KEY_ID=v1
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
# FreeSWITCH hardening declarations (read by pnpm check:freeswitch-hardening).
# Set these to confirm production hardening has been applied.
# FREESWITCH_ANONYMOUS_CALLS=disabled
# FREESWITCH_MOD_XML_RPC=disabled
# FREESWITCH_LOG_LEVEL=warning
# Production network config declarations (read by pnpm check:network-config).
# Not wired into the API or Go agent -- set to confirm configuration has been applied.
# FREESWITCH_EXTERNAL_SIP_IP=203.0.113.10
# FREESWITCH_EXTERNAL_RTP_IP=203.0.113.10
# FREESWITCH_RTP_PORT_MIN=16384
# FREESWITCH_RTP_PORT_MAX=32768
# SIP_TLS_ENABLED=true
# SRTP_POLICY=optional
# MANAGECALLAI_TRUST_PROXY=1
FREESWITCH_AGENT_LOG_LEVEL=info
API_BASE_URL=http://localhost:3000
WORKER_PORT=3400
# One freeswitch-agent instance per tenant -- set to the tenant UUID this agent forwards events for.
MANAGECALLAI_TENANT_ID=
MANAGECALLAI_DIRECTORY_URL=http://api:3000/api/v1/freeswitch/directory
MANAGECALLAI_API_BASE=http://api:3000/api/v1
FREESWITCH_VERSION=v1.10.12
LOG_LEVEL=info
# Platform operator access: comma-separated emails granted read access to /api/v1/platform/* endpoints.
PLATFORM_OPERATOR_EMAILS=admin@example.com
# First-run bootstrap (optional for local headless setup)
SETUP_TENANT_NAME=Platform
SETUP_TENANT_SLUG=platform
SETUP_ADMIN_EMAIL=admin@example.com
SETUP_ADMIN_PASSWORD=
ALLOW_REMOTE_SETUP=false
# Optional: override health probe URLs (defaults below match local dev ports).
PLATFORM_API_HEALTH_URL=http://localhost:3000/health
PLATFORM_WORKER_HEALTH_URL=http://localhost:3400/health
WEBHOOK_WORKER_INTERVAL_MS=1000
RECORDING_STORAGE_ROOT=recordings
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_RUNTIME_MAX=1200
RATE_LIMIT_WEBHOOK_MAX=300
RATE_LIMIT_OUTBOUND_MAX=60
RATE_LIMIT_API_MAX=600
RATE_LIMIT_SCRAPE_MAX=30
# Multi-instance rate limiting (issue #59):
# The default in-process rate limiter is per-process and not safe for horizontal scaling.
# For single-instance deployments, leave MANAGECALLAI_INSTANCE_COUNT=1 (default).
# For multi-instance production deployments you MUST either:
#   - Front the API with a gateway that enforces rate limits (set EDGE_RATE_LIMIT_ENFORCED=true), or
#   - Use the built-in Redis shared store (set RATE_LIMIT_STORE=redis and RATE_LIMIT_REDIS_URL=...)
#   - Use another external shared limiter (set RATE_LIMIT_EXTERNAL_ENFORCED=true and name RATE_LIMIT_STORE)
# The production preflight will fail if instance count > 1 without one of these set.
MANAGECALLAI_INSTANCE_COUNT=1
# RATE_LIMIT_EXTERNAL_ENFORCED=false
# EDGE_RATE_LIMIT_ENFORCED=false
# RATE_LIMIT_STORE=redis
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT_REDIS_KEY_PREFIX=managecallai:rate-limit

# MCP stdio server (apps/mcp) -- used with Claude Desktop or similar MCP clients.
# Create a key via: POST /api/v1/automation/keys
MANAGECALL_API_URL=http://localhost:3000
MANAGECALL_API_KEY=mcak_your_key_here
