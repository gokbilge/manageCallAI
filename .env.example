POSTGRES_DB=managecallai
POSTGRES_USER=managecallai
POSTGRES_PASSWORD=managecallai
POSTGRES_PORT=5432
DATABASE_URL=postgres://managecallai:managecallai@localhost:5432/managecallai
API_PORT=3000
JWT_SECRET=change-me-to-a-long-random-string-in-production
RUNTIME_API_TOKEN=change-me-runtime-token
# AES-256-GCM key for SIP password encryption-at-rest.
# Must be 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
SIP_SECRET_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Identifies the active key; stored alongside every ciphertext for future key rotation.
SIP_SECRET_KEY_ID=v1
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
API_BASE_URL=http://localhost:3000
LOG_LEVEL=info
WORKER_PORT=3400
