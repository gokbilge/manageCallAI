# Pro self-hosted example environment
# Use with: docker compose --env-file .env.pro -f docker-compose.pro.yml up -d

MANAGECALLAI_IMAGE_TAG=latest
MANAGECALLAI_EDITION=pro

POSTGRES_DB=managecallai
POSTGRES_USER=managecallai
POSTGRES_PASSWORD=change-me-postgres-password

API_PORT=3000
WORKER_PORT=3400
APP_ENV=production

JWT_SECRET=change-me-to-a-long-random-string-in-production
RUNTIME_API_TOKEN=change-me-runtime-token
SIP_SECRET_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SIP_SECRET_KEY_ID=v1

FREESWITCH_ESL_PASSWORD=change-me-freeswitch-esl-password
FREESWITCH_EXTERNAL_SIP_IP=203.0.113.10
FREESWITCH_EXTERNAL_RTP_IP=203.0.113.10

MANAGECALLAI_LICENSE_FILE=/etc/managecallai/license/license.json
MANAGECALLAI_LICENSE_PUBLIC_KEY=/etc/managecallai/license/public.pem
MANAGECALLAI_LICENSE_GRACE_DAYS=14

# Missing or invalid license should fall back to safe degraded Free behavior
# once API-side entitlement verification is implemented.
